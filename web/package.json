{
  "name": "crosswalk-review-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev.ts",
    "dev:client": "portless --name crosswalk-review sh -c 'bunx vite --host \"$HOST\" --port \"$PORT\"'",
    "dev:client:direct": "bunx vite",
    "dev:url": "portless get crosswalk-review",
    "dev:tailnet:url": "bun run tailnet-url.ts",
    "validate:map": "bun run run-map-validation.ts",
    "lint": "bunx eslint .",
    "build": "bunx vite build",
    "preview": "bunx vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "papaparse": "^5.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-leaflet": "^5.0.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "bun-types": "^1.3.9",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.37.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.6"
  }
}
